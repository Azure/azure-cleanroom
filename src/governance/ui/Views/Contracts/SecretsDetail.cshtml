@model SecretsViewModel
@{
    ViewData["Title"] = "Secrets Management";
}

<div class="content-wrapper">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-gradient mb-1">
                <i class="fas fa-key me-2"></i>Secrets Management
            </h1>
            <p class="text-muted mb-0">Manage secure secrets and credentials for the clean room</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="refreshSecrets()">
                <i class="fas fa-sync-alt me-1"></i>Refresh
            </button>
            <a href="/Contracts" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i>Back to Contracts
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <!-- Secrets List Card -->
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-list me-2"></i>Secret Inventory
                        @if (Model.Value != null && Model.Value.Any())
                        {
                            <span class="badge bg-primary ms-2">@Model.Value.Count()</span>
                        }
                    </h5>
                    <div class="d-flex gap-2">
                        <div class="input-group input-group-sm" style="width: 250px;">
                            <span class="input-group-text">
                                <i class="fas fa-search"></i>
                            </span>
                            <input type="text" class="form-control" placeholder="Search secrets..." id="secretSearch"
                                onkeyup="filterSecrets()">
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (Model.Value != null && Model.Value.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0" id="secretsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th class="border-0">
                                            <i class="fas fa-key me-1"></i>Secret ID
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (Secret item in Model.Value)
                                    {
                                        <tr class="secret-row">
                                            <td>
                                                <a asp-controller="Contracts" asp-action="SecretIdDetail"
                                                    asp-route-id="@Model.ContractId" asp-route-secretId="@item.SecretId"
                                                    class="text-decoration-none">
                                                    <div class="d-flex align-items-center">
                                                        <div class="secret-icon me-2">
                                                            <i class="fas fa-key text-primary"></i>
                                                        </div>
                                                        <div>
                                                            <strong class="font-monospace text-primary">@item.SecretId</strong>
                                                            <br>
                                                            <small class="text-muted">Click to view details</small>
                                                        </div>
                                                    </div>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-key fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No Secrets Found</h5>
                            <p class="text-muted mb-0">No secrets have been configured for this contract yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">


        </div>
        </div>
    </div>
</div>

<script>
    function filterSecrets() {
        const searchInput = document.getElementById('secretSearch').value.toLowerCase();
        const rows = document.querySelectorAll('.secret-row');

        rows.forEach(row => {
            const secretId = row.querySelector('.font-monospace').textContent.toLowerCase();
            if (secretId.includes(searchInput)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function refreshSecrets() {
        const refreshBtn = document.querySelector('[onclick="refreshSecrets()"]');
        const icon = refreshBtn.querySelector('i');

        icon.classList.add('fa-spin');
        refreshBtn.disabled = true;

        setTimeout(() => {
            icon.classList.remove('fa-spin');
            refreshBtn.disabled = false;
            location.reload();
        }, 1000);
    }






</script>

<style>
    .secret-icon {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(13, 110, 253, 0.1);
        border-radius: 50%;
    }

    .secret-row:hover {
        background-color: rgba(0, 0, 0, 0.02);
        cursor: pointer;
    }

    .secret-row:hover .secret-icon {
        background-color: rgba(13, 110, 253, 0.2);
    }

    .secret-row a:hover .text-primary {
        color: var(--bs-primary-dark) !important;
    }
</style>