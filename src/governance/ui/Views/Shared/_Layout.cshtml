<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Azure Clean Room Governance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cgs_ui.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <!-- Mobile Header (visible on small screens) -->
    <div class="mobile-header d-lg-none">
        <button class="mobile-menu-toggle" type="button">
            <i class="fas fa-bars"></i>
        </button>
        <div class="mobile-brand">
            <i class="fas fa-shield-alt"></i>
            <span>Azure Clean Room Governance</span>
        </div>
    </div>

    <!-- Sidebar Navigation -->
    <nav class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <i class="fas fa-shield-alt brand-icon"></i>
                <span>Azure Clean Room Governance</span>
            </div>
            <button class="sidebar-toggle d-none d-lg-block" type="button">
                <i class="fas fa-angle-left"></i>
            </button>
        </div>

        <div class="sidebar-menu">
            <a href="@Url.Action("Index", "Home")" class="sidebar-link">
                <i class="fas fa-home"></i>
                <span>Dashboard</span>
            </a>
            <a href="@Url.Action("Index", "Contracts")" class="sidebar-link">
                <i class="fas fa-file-contract"></i>
                <span>Contracts</span>
            </a>
            <a href="@Url.Action("Index", "UserDocuments")" class="sidebar-link">
                <i class="fas fa-file-alt"></i>
                <span>User Documents</span>
            </a>
            <a href="@Url.Action("Index", "Oidc")" class="sidebar-link">
                <i class="fas fa-key"></i>
                <span>OIDC</span>
            </a>
            <a href="@Url.Action("Index", "Members")" class="sidebar-link">
                <i class="fas fa-users"></i>
                <span>Members</span>
            </a>
            <a href="@Url.Action("Index", "Users")" class="sidebar-link">
                <i class="fas fa-user-friends"></i>
                <span>Users</span>
            </a>
            <a href="@Url.Action("Index", "Settings")" class="sidebar-link">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
        </div>

        <div class="sidebar-footer">
            <div class="connection-status">
                @{
                    var isConnected = !string.IsNullOrEmpty(CgsUI.Controllers.Common.ConnectedTo);
                }
                <div class="status-indicator @(isConnected ? "connected" : "disconnected")"></div>
                <div>
                    <div class="status-text">@(isConnected ? "Connected" : "Disconnected")</div>
                    @if (isConnected)
                    {
                        <div class="connection-details">@CgsUI.Controllers.Common.ConnectedTo</div>
                    }
                    else
                    {
                        <div class="connection-details">No connection</div>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <main role="main">
            @RenderBody()
        </main>

        <footer class="mt-5 py-4 text-center text-muted" style="border-top: 1px solid #e2e8f0;">
            <div class="container">
                <small>&copy; @DateTime.Now.Year Microsoft Corporation.</small>
            </div>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>