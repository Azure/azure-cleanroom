@model HomeViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="content-wrapper">
    <!-- Welcome Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-gradient mb-1">Azure Clean Room Governance</h1>
            <p class="text-muted mb-0">Secure confidential computing governance and policy management</p>
        </div>
        <div class="d-flex gap-2">
            <a href="/Settings" class="btn btn-primary btn-sm">
                <i class="fas fa-cog me-1"></i>Settings
            </a>
        </div>
    </div>

    <!-- Status Alerts -->
    @if (Model.UpdatesAvailable)
    {
        <div class="alert alert-info d-flex align-items-center" role="alert">
            <i class="fas fa-info-circle me-3"></i>
            <div>
                <strong>Updates Available</strong><br>
                <small>Navigate to Settings to see the latest updates and apply them.</small>
            </div>
            <a href="/Settings" class="btn btn-sm btn-outline-primary ms-auto">
                <i class="fas fa-arrow-right me-1"></i>View Updates
            </a>
        </div>
    }

    @if (!Model.Connected)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="fas fa-exclamation-triangle me-3"></i>
            <div>
                <strong>Service Disconnected</strong><br>
                <small>cgs-client is not responding. Check that the container is running and inspect the logs.</small>
            </div>
            <button type="button" class="btn btn-sm btn-outline-warning ms-auto" onclick="location.reload()">
                <i class="fas fa-sync-alt me-1"></i>Retry Connection
            </button>
        </div>
    }
    else if (!Model.Configured)
    {
        <div class="alert alert-warning d-flex align-items-center" role="alert">
            <i class="fas fa-cog me-3"></i>
            <div>
                <strong>Configuration Required</strong><br>
                <small>cgs-client is not configured. Navigate to Settings to configure it or re-deploy the client.</small>
            </div>
            <a href="/Settings" class="btn btn-sm btn-outline-warning ms-auto">
                <i class="fas fa-arrow-right me-1"></i>Configure Now
            </a>
        </div>
    }

    <!-- System Status Cards -->
    <div class="card-stats">
        <div class="stat-card">
            <div class="stat-icon @(Model.Connected ? "success" : "danger")">
                <i class="fas @(Model.Connected ? "fa-check-circle" : "fa-times-circle")"></i>
            </div>
            <div class="stat-value">@(Model.Connected ? "Online" : "Offline")</div>
            <div class="stat-label">Service Status</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon @(Model.Configured ? "primary" : "warning")">
                <i class="fas @(Model.Configured ? "fa-shield-alt" : "fa-exclamation-triangle")"></i>
            </div>
            <div class="stat-value">@(Model.Configured ? "Ready" : "Pending")</div>
            <div class="stat-label">Configuration</div>
        </div>

        <div class="stat-card">
            <div class="stat-icon @(Model.UpdatesAvailable ? "warning" : "success")">
                <i class="fas @(Model.UpdatesAvailable ? "fa-download" : "fa-check")"></i>
            </div>
            <div class="stat-value">@(Model.UpdatesAvailable ? "Available" : "Current")</div>
            <div class="stat-label">Updates</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="fas fa-rocket me-2 text-primary"></i>Quick Actions
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <a href="/Contracts" class="btn btn-outline-primary w-100 text-start">
                        <i class="fas fa-file-contract me-2"></i>
                        <div>
                            <strong>Manage Contracts</strong>
                            <small class="d-block text-muted">View and manage governance contracts</small>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/Members" class="btn btn-outline-primary w-100 text-start">
                        <i class="fas fa-users me-2"></i>
                        <div>
                            <strong>Member Management</strong>
                            <small class="d-block text-muted">Add and manage consortium members</small>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/UserDocuments" class="btn btn-outline-primary w-100 text-start">
                        <i class="fas fa-file-alt me-2"></i>
                        <div>
                            <strong>User Documents</strong>
                            <small class="d-block text-muted">Manage user documents</small>
                        </div>
                    </a>
                </div>
                <div class="col-md-6">
                    <a href="/Users" class="btn btn-outline-primary w-100 text-start">
                        <i class="fas fa-user-friends me-2"></i>
                        <div>
                            <strong>User Management</strong>
                            <small class="d-block text-muted">View and manage consortium users</small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>