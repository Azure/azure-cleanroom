@model OidcIssuerViewModel
@{
    ViewData["Title"] = "OIDC Issuer";
}

<div class="content-wrapper">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-gradient mb-1">
                <i class="fas fa-id-card me-2"></i>OIDC Issuer
            </h1>
            <p class="text-muted mb-0">OpenID Connect Identity Provider configuration and settings</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="refreshIssuer()">
                <i class="fas fa-sync-alt me-1"></i>Refresh
            </button>
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="copyConfiguration()"
                title="Copy configuration to clipboard">
                <i class="fas fa-copy me-1"></i>Copy Config
            </button>
        </div>
    </div>

    <div class="row">
        <!-- OIDC Configuration Card -->
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-cog me-2"></i>OIDC Configuration
                    </h5>
                    @if (Model.Enabled)
                    {
                        <span class="badge bg-success">
                            <i class="fas fa-check-circle me-1"></i>Enabled
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">
                            <i class="fas fa-pause-circle me-1"></i>Disabled
                        </span>
                    }
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Enabled Status -->
                        <div class="col-md-6 mb-3">
                            <div class="config-item">
                                <small class="text-muted d-block">Status</small>
                                <div class="mt-1">
                                    @if (Model.Enabled)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle me-1"></i>Enabled
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">
                                            <i class="fas fa-pause-circle me-1"></i>Disabled
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Issuer URL -->
                        <div class="col-md-12 mb-3">
                            <div class="config-item">
                                <small class="text-muted d-block">Issuer URL</small>
                                <div class="mt-1">
                                    @if (!string.IsNullOrEmpty(Model.IssuerUrl))
                                    {
                                        <div class="d-flex align-items-center">
                                            <code class="bg-light p-2 rounded flex-grow-1 me-2">@Model.IssuerUrl</code>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                                onclick="copyToClipboard('@Model.IssuerUrl')" title="Copy URL">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning d-flex align-items-center mb-0">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            <small>Issuer URL not configured</small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.TenantData?.TenantId != null)
                    {
                        <hr>
                        <h6 class="text-primary mb-3">
                            <i class="fas fa-building me-1"></i>Tenant Information
                        </h6>

                        <div class="row">
                            <!-- Tenant ID -->
                            <div class="col-md-6 mb-3">
                                <div class="config-item">
                                    <small class="text-muted d-block">Tenant ID</small>
                                    <div class="mt-1">
                                        <div class="d-flex align-items-center">
                                            <code
                                                class="bg-light p-2 rounded flex-grow-1 me-2">@Model.TenantData.TenantId</code>
                                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                                onclick="copyToClipboard('@Model.TenantData.TenantId')"
                                                title="Copy Tenant ID">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tenant Issuer URL -->
                            <div class="col-md-12 mb-3">
                                <div class="config-item">
                                    <small class="text-muted d-block">Tenant Issuer URL</small>
                                    <div class="mt-1">
                                        @if (!string.IsNullOrEmpty(Model.TenantData.IssuerUrl))
                                        {
                                            <div class="d-flex align-items-center">
                                                <code
                                                    class="bg-light p-2 rounded flex-grow-1 me-2">@Model.TenantData.IssuerUrl</code>
                                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                                    onclick="copyToClipboard('@Model.TenantData.IssuerUrl')"
                                                    title="Copy Tenant URL">
                                                    <i class="fas fa-copy"></i>
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <code class="bg-light p-2 rounded d-block">Not configured</code>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>


    </div>
</div>

<script>
    function refreshIssuer() {
        const refreshBtn = document.querySelector('[onclick="refreshIssuer()"]');
        const icon = refreshBtn.querySelector('i');

        icon.classList.add('fa-spin');
        refreshBtn.disabled = true;

        setTimeout(() => {
            icon.classList.remove('fa-spin');
            refreshBtn.disabled = false;
            location.reload();
        }, 1000);
    }

    function copyToClipboard(text) {
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(text).then(() => {
                showCopySuccess();
            });
        } else {
            // Fallback for older browsers
            const textArea = document.createElement('textarea');
            textArea.value = text;
            document.body.appendChild(textArea);
            textArea.select();
            document.execCommand('copy');
            document.body.removeChild(textArea);
            showCopySuccess();
        }
    }

    function copyConfiguration() {
        const config = {
            enabled: @Model.Enabled.ToString().ToLower(),
            issuerUrl: "@(Model.IssuerUrl ?? "")",
            @if (Model.TenantData?.TenantId != null)
            {
                <text>
                    tenantData: {
                        tenantId: "@Model.TenantData.TenantId",
                    issuerUrl: "@(Model.TenantData.IssuerUrl ?? "")"
                        }
                </text>
        }
        };

    const configJson = JSON.stringify(config, null, 2);
    copyToClipboard(configJson);
    }

    function showCopySuccess() {
        // Create a temporary toast or notification
        const toast = document.createElement('div');
        toast.className = 'position-fixed top-0 end-0 m-3 alert alert-success alert-dismissible';
        toast.style.zIndex = '9999';
        toast.innerHTML = `
            <i class="fas fa-check-circle me-2"></i>
            <span>Copied to clipboard!</span>
            <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
        `;
        document.body.appendChild(toast);

        // Auto-remove after 3 seconds
        setTimeout(() => {
            if (toast.parentElement) {
                toast.remove();
            }
        }, 3000);
    }
</script>

<style>
    .config-item {
        min-height: 60px;
    }

    .config-item code {
        word-break: break-all;
        white-space: pre-wrap;
    }

    .card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .text-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .alert {
        border: none;
        border-radius: 8px;
    }

    .badge {
        font-size: 0.75em;
    }
</style>