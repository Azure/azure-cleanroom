@model ProposalViewModel
@{
    ViewData["Title"] = "Proposal Details";
}

<div class="content-wrapper">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 text-gradient mb-1">
                <i class="fas fa-file-alt me-2"></i>Proposal Details
            </h1>
            <p class="text-muted mb-0">View and manage governance proposal</p>
        </div>
        <div>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="refreshProposal()">
                <i class="fas fa-sync-alt me-1"></i>Refresh
            </button>
        </div>
    </div>

    <!-- Proposal ID Header -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center">
                <div class="proposal-icon me-3">
                    <i class="fas fa-file-alt fa-2x text-primary"></i>
                </div>
                <div>
                    <h4 class="mb-1 font-monospace">@Model.ProposalId</h4>
                    <div class="d-flex align-items-center">
                        @{
                            var statusClass = Model.IsOpen ? "badge bg-warning text-dark" : "badge bg-secondary";
                            var statusText = Model.IsOpen ? "Open" : "Closed";
                        }
                        <span class="@statusClass me-2">
                            <i class="fas fa-circle me-1" style="font-size: 0.5rem;"></i>
                            @statusText
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    @if (Model.IsOpen)
    {
        if (!Model.CanVote)
        {
            <div class="alert alert-warning mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <i class="fas fa-info-circle me-2"></i>
                        @Model.DisableVoteReason
                    </div>
                    @if (Model.CanWithdraw)
                    {
                        <a asp-controller="Proposals" asp-action="Withdraw" asp-route-proposalId="@Model.ProposalId"
                            class="btn btn-outline-warning">
                            <i class="fas fa-times me-1"></i>Withdraw Proposal
                        </a>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info mb-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <i class="fas fa-vote-yea me-2"></i>
                        This proposal is open for voting.
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-controller="Proposals" asp-action="VoteAccept" asp-route-proposalId="@Model.ProposalId"
                            class="btn btn-success">
                            <i class="fas fa-check me-1"></i>Accept
                        </a>
                        <a asp-controller="Proposals" asp-action="VoteReject" asp-route-proposalId="@Model.ProposalId"
                            class="btn btn-danger">
                            <i class="fas fa-times me-1"></i>Reject
                        </a>
                        @if (Model.CanWithdraw)
                        {
                            <a asp-controller="Proposals" asp-action="Withdraw" asp-route-proposalId="@Model.ProposalId"
                                class="btn btn-outline-secondary">
                                <i class="fas fa-trash me-1"></i>Withdraw
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    }

    <!-- Proposal Content -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fas fa-file-code me-2"></i>Proposal Content
            </h5>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="copyProposalContent()"
                title="Copy content to clipboard">
                <i class="fas fa-copy me-1"></i>Copy
            </button>
        </div>
        <div class="card-body">
            <div class="code-container">
                <pre class="bg-light p-3 rounded" id="proposalContent"><code>@Model.Proposal</code></pre>
            </div>
        </div>
    </div>

    <!-- Votes Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="fas fa-vote-yea me-2"></i>Member Votes
            </h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Votes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">
                                    <i class="fas fa-user me-1"></i>Member ID
                                </th>
                                <th scope="col">
                                    <i class="fas fa-tag me-1"></i>Name
                                </th>
                                <th scope="col">
                                    <i class="fas fa-check-circle me-1"></i>Vote
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vote in Model.Votes)
                            {
                                <tr>
                                    <td>
                                        <span class="font-monospace">@vote.MemberId</span>
                                    </td>
                                    <td>
                                        <span class="fw-medium">@vote.MemberName</span>
                                    </td>
                                    <td>
                                        @{
                                            var voteClass = vote.Vote?.ToLower() switch
                                            {
                                                "accept" => "badge bg-success",
                                                "reject" => "badge bg-danger",
                                                "true" => "badge bg-success",
                                                "false" => "badge bg-danger",
                                                _ => "badge bg-secondary"
                                            };

                                            var voteText = vote.Vote?.ToLower() switch
                                            {
                                                "true" => "Accept",
                                                "false" => "Reject",
                                                _ => vote.Vote
                                            };
                                        }
                                        <span class="@voteClass">
                                            @voteText
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-4">
                    <i class="fas fa-vote-yea fa-2x text-muted mb-2"></i>
                    <p class="text-muted mb-0">No votes cast yet</p>
                </div>
            }
        </div>
    </div>

    <!-- Actions Section -->
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">
                <i class="fas fa-cogs me-2"></i>Proposal Actions
            </h5>
            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="copyActions()"
                title="Copy actions to clipboard">
                <i class="fas fa-copy me-1"></i>Copy
            </button>
        </div>
        <div class="card-body">
            <div class="code-container">
                <pre class="bg-light p-3 rounded" id="actionsContent"><code>@Model.Actions</code></pre>
            </div>
        </div>
    </div>
</div>

<script>
    function copyProposalContent() {
        const contentElement = document.getElementById('proposalContent');
        const copyButton = document.querySelector('[onclick="copyProposalContent()"]');
        const originalText = copyButton.innerHTML;

        if (contentElement) {
            const textContent = contentElement.textContent || contentElement.innerText || '';

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(textContent).then(() => {
                    copyButton.innerHTML = '<i class="fas fa-check me-1"></i>Copied!';
                    copyButton.classList.remove('btn-outline-secondary');
                    copyButton.classList.add('btn-success');

                    setTimeout(() => {
                        copyButton.innerHTML = originalText;
                        copyButton.classList.remove('btn-success');
                        copyButton.classList.add('btn-outline-secondary');
                    }, 2000);
                });
            }
        }
    }

    function copyActions() {
        const contentElement = document.getElementById('actionsContent');
        const copyButton = document.querySelector('[onclick="copyActions()"]');
        const originalText = copyButton.innerHTML;

        if (contentElement) {
            const textContent = contentElement.textContent || contentElement.innerText || '';

            if (navigator.clipboard && window.isSecureContext) {
                navigator.clipboard.writeText(textContent).then(() => {
                    copyButton.innerHTML = '<i class="fas fa-check me-1"></i>Copied!';
                    copyButton.classList.remove('btn-outline-secondary');
                    copyButton.classList.add('btn-success');

                    setTimeout(() => {
                        copyButton.innerHTML = originalText;
                        copyButton.classList.remove('btn-success');
                        copyButton.classList.add('btn-outline-secondary');
                    }, 2000);
                });
            }
        }
    }

    function refreshProposal() {
        const refreshBtn = document.querySelector('[onclick="refreshProposal()"]');
        const icon = refreshBtn.querySelector('i');

        icon.classList.add('fa-spin');
        refreshBtn.disabled = true;

        setTimeout(() => {
            icon.classList.remove('fa-spin');
            refreshBtn.disabled = false;
            location.reload();
        }, 1000);
    }
</script>