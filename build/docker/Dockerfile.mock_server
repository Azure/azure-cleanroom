# Use the official .NET Core SDK as the base image
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build

# Set the working directory
WORKDIR /app

# copy csproj and restore as distinct layers
# https://blog.nimbleways.com/docker-build-caching-for-dotnet-applications-done-right-with-dotnet-subset/
COPY Directory.Packages.props /app
COPY Directory.Build.props /app
COPY test/onebox/frontendservice/mock-server/*.sln /app/test/onebox/frontendservice/mock-server/
COPY test/onebox/frontendservice/mock-server/*.csproj /app/test/onebox/frontendservice/mock-server/
COPY src/internal/Attestation/*.csproj /app/src/internal/Attestation/
COPY src/internal/restapi-common/*.csproj /app/src/internal/restapi-common/
COPY src/internal/Cose/*.csproj /app/src/internal/Cose/
COPY src/workloads/frontend/Models /app/src/workloads/frontend/Models
COPY src/workloads/frontend/Utils /app/src/workloads/frontend/Utils
RUN dotnet restore /app/test/onebox/frontendservice/mock-server/mock-server.sln

# copy everything else and build app
COPY stylecop.json /app
COPY Menees.Analyzers.Settings.xml /app
COPY .editorconfig /app
COPY src/internal /app/src/internal
COPY test/onebox/frontendservice/mock-server /app/test/onebox/frontendservice/mock-server

# Publish the application
RUN dotnet publish -c Release --no-restore -o /app/publish /app/test/onebox/frontendservice/mock-server/mock-server.csproj

# Use the official .NET Core runtime as the base image for the final stage
FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends curl jq \
    && rm -rf /var/lib/apt/lists/*

# Set the working directory
WORKDIR /app

# Copy the published output from the build stage to the runtime stage
COPY --from=build /app/publish .

# Listen on 8386 within the container.
ARG PORT=8386
ENV ASPNETCORE_URLS=http://+:${PORT}

# Set the entry point for the container
ENTRYPOINT ["dotnet", "/app/mock-server.dll"]