# Build stage
FROM golang:1.24-alpine AS builder

WORKDIR /app

# Copy go mod files first (changes less frequently)
COPY go.mod go.sum ./
RUN go mod download

# Copy only the Go source files needed for the build
COPY src/cvm/cmd/cvm-attestation-agent/ ./src/cvm/cmd/cvm-attestation-agent/
COPY src/cvm/pkg/ ./src/cvm/pkg/

# Build the binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /cvm-attestation-agent ./src/cvm/cmd/cvm-attestation-agent

# Runtime stage
FROM alpine:3.19

RUN apk --no-cache add ca-certificates

WORKDIR /app

# Copy the binary from builder
COPY --from=builder /cvm-attestation-agent /app/cvm-attestation-agent

# Expose the default port
EXPOSE 8900

# Run the server
ENTRYPOINT ["/app/cvm-attestation-agent"]
CMD ["-addr", ":8900"]
