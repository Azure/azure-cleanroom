FROM cleanroombuild.azurecr.io/mirror/docker/library/python:3.12 AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y curl build-essential && rm -rf /var/lib/apt/lists/*
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

COPY src/workloads/analytics/analytics-app src/workloads/analytics/analytics-app
COPY src/workloads/analytics/contracts src/workloads/analytics/contracts
COPY src/internal/cleanroom-internal src/internal/cleanroom-internal
COPY src/sdk src/sdk
COPY pyproject.toml .
COPY uv.lock .
RUN uv sync --frozen

RUN uv build --all-packages --wheel

# Build stage for Scala/sbt plugin
FROM cleanroombuild.azurecr.io/mirror/docker/library/sbtscala/scala-sbt:eclipse-temurin-21.0.8_9_1.11.7_3.7.4 AS plugin-builder

WORKDIR /plugin

COPY src/workloads/analytics/monitoring_plugin /plugin
RUN sbt assembly

FROM cleanroombuild.azurecr.io/mirror/docker/library/ubuntu/spark:4.0.0-python3

USER root

WORKDIR /setup

COPY --from=builder /build/dist/cleanroom_internal*.whl /setup/
COPY --from=builder /build/dist/cleanroom_sdk*.whl /setup/
COPY --from=builder /build/dist/analytics_contracts*.whl /setup/

# Install pip and wheels
RUN curl -sS https://bootstrap.pypa.io/get-pip.py | python3 - --break-system-packages \
  && python3 -m pip install --no-cache-dir --break-system-packages *.whl \
  && rm -f *.whl

WORKDIR /app
COPY /src/workloads/analytics/analytics-app .
RUN pip install --no-cache-dir --break-system-packages .

RUN mkdir -p /plugins \
  && curl -fL \
  https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/latest/download/opentelemetry-javaagent.jar \
  -o /plugins/opentelemetry-javaagent.jar \
  && curl -fL \
  https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-api/1.34.0/opentelemetry-api-1.34.0.jar \
  -o /plugins/opentelemetry-api-1.34.0.jar \
  && curl -fL \
  https://repo1.maven.org/maven2/io/opentelemetry/opentelemetry-context/1.34.0/opentelemetry-context-1.34.0.jar \
  -o /plugins/opentelemetry-context-1.34.0.jar

# Copy the Cleanroom Monitoring plugin
COPY --from=plugin-builder /plugin/dist/cleanroom-monitoring-plugin.jar /plugins/cleanroom-monitoring-plugin.jar

RUN chown spark /plugins \
  && chown spark /app

# The spark uid is mentioned in the spark image. Set it back as the current user.
USER spark

# Set PYTHONUNBUFFERED to ensure that Python output is sent straight to the terminal without buffering.
# Otherwise, the output may be buffered and not appear immediately.
ENV PYTHONUNBUFFERED=1

# Need to add this environment variable so the relative imports in the Python code work correctly.
ENV PYTHONPATH="${PYTHONPATH}:/app/src/analytics_workload"

# We will override the entrypoint of the spark image with our own script.
# This script will wait for all the mount points to be available and then call the original
# entrypoint script with the original arguments.
ENTRYPOINT ["python3", "/app/src/analytics_workload/spark_launcher.py"]