FROM cleanroombuild.azurecr.io/mirror/docker/library/python:3.12 AS builder

WORKDIR /build

RUN apt-get update && apt-get install -y curl build-essential && rm -rf /var/lib/apt/lists/*
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

COPY pyproject.toml .
COPY uv.lock .

# Build each package separately so that only changed packages are rebuilt.
COPY src/sdk src/sdk
RUN uv build --package cleanroom-sdk --wheel

COPY src/internal/cleanroom-internal src/internal/cleanroom-internal
RUN uv build --package cleanroom-internal --wheel

COPY src/internal/frontend-internal src/internal/frontend-internal
RUN uv build --package frontend-internal --wheel

COPY src/workloads/inferencing/kserve-inferencing-frontend src/workloads/inferencing/kserve-inferencing-frontend
RUN uv build --package kserve-inferencing-frontend --wheel

FROM cleanroombuild.azurecr.io/mirror/docker/library/python:3.12

WORKDIR /setup

COPY --from=builder /build/dist/cleanroom_sdk*.whl /setup/
RUN pip install cleanroom_sdk*.whl && rm -f cleanroom_sdk*.whl

COPY --from=builder /build/dist/cleanroom_internal*.whl /setup/
RUN pip install cleanroom_internal*.whl && rm -f cleanroom_internal*.whl

COPY --from=builder /build/dist/frontend_internal*.whl /setup/
RUN pip install frontend_internal*.whl && rm -f frontend_internal*.whl

COPY --from=builder /build/dist/kserve_inferencing_frontend*.whl /setup/
RUN pip install kserve_inferencing_frontend*.whl && rm -f kserve_inferencing_frontend*.whl

EXPOSE 8000

# Set PYTHONUNBUFFERED to ensure that Python output is sent straight to the terminal without buffering.
# Otherwise, the output may be buffered and not appear immediately.
ENV PYTHONUNBUFFERED=1
