[
  {
    "name": "ccr-proxy",
    "properties": {
      "image": "$containerRegistryUrl/ccr-proxy@$digest",
      "environmentVariables": [
        {
          "name": "CCR_ENVOY_DESTINATION_PORT",
          "value": ".*",
          "regex": true
        },
        {
          "name": "CCR_ENVOY_SERVICE_CERT_OUTPUT_FILE",
          "value": ".*",
          "regex": true
        }
      ],
      "volumeMounts": [
        {
          "name": "certs",
          "mountPath": "/app/certs",
          "mountType": "emptyDir",
          "readOnly": false
        }
      ],
      "command": [
        "/bin/bash",
        "https-http/bootstrap.sh",
        "--ca-type",
        "local"
      ]
    }
  },
  {
    "name": "skr",
    "properties": {
      "image": "$containerRegistryUrl/skr@$digest",
      "command": [
        "/skr.sh"
      ],
      "environmentVariables": [
        {
          "name": "SkrSideCarArgs",
          "value": "ewogICAiY2VydGNhY2hlIjogewogICAgICAiZW5kcG9pbnQiOiAiYW1lcmljYXMuYWNjY2FjaGUuYXp1cmUubmV0IiwKICAgICAgInRlZV90eXBlIjogIlNldlNucFZNIiwKICAgICAgImFwaV92ZXJzaW9uIjogImFwaS12ZXJzaW9uPTIwMjAtMTAtMTUtcHJldmlldyIKICAgfQp9"
        },
        {
          "name": "Port",
          "value": ".*",
          "regex": true
        },
        {
          "name": "LogFile",
          "value": ".*",
          "regex": true
        },
        {
          "name": "LogLevel",
          "value": "Info"
        }
      ]
    }
  },
  {
    "name": "ccf-recovery-agent",
    "properties": {
      "image": "$containerRegistryUrl/ccf/ccf-recovery-agent@$digest",
      "command": [],
      "environmentVariables": [
        {
          "name": "CCF_ENDPOINT",
          "value": "localhost:.*",
          "regex": true
        },
        {
          "name": "CCF_ENDPOINT_SKIP_TLS_VERIFY",
          "value": ".*",
          "regex": true
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": ".*",
          "regex": true
        },
        {
          "name": "SERVICE_CERT_LOCATION",
          "value": ".*",
          "regex": true
        }
      ],
      "volumeMounts": [
        {
          "name": "certs",
          "mountPath": "/app/certs",
          "mountType": "emptyDir",
          "readOnly": false
        }
      ]
    }
  },
  {
    "name": "cvm-attestation-verifier",
    "properties": {
      "image": "$containerRegistryUrl/cvm/cvm-attestation-verifier@$digest",
      "command": [],
      "environmentVariables": []
    }
  },
  {
    "name": "ccf-cchost",
    "properties": {
      "image": "$containerRegistryUrl/ccf/app/run-js/snp@$digest",
      "command": [],
      "environmentVariables": [
        {
          "name": "CONFIG_DATA_TGZ",
          "value": ".*",
          "regex": true
        },
        {
          "name": "CCF_LOG_LEVEL",
          "value": ".*",
          "regex": true
        },
        {
          "name": "LOGS_DIR",
          "value": ".*",
          "regex": true
        },
        {
          "name": "CCR_ATTESTATION_HOST",
          "value": "localhost"
        },
        {
          "name": "CCR_ATTESTATION_PORT",
          "value": ".*",
          "regex": true
        }
      ],
      "volumeMounts": [
