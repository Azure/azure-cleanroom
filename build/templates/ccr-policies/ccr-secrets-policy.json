{
  "name": "ccr-secrets",
  "properties": {
    "image": "$containerRegistryUrl/ccr-secrets@$digest",
    "command": [],
    "environmentVariables": [
      {
        "name": "IDENTITY_PORT",
        "value": "$identityPort"
      },
      {
        "name": "SKR_PORT",
        "value": "$skrPort"
      },
      {
        "name": "TELEMETRY_MOUNT_PATH",
        "value": "$telemetryMountPath"
      }
    ],
    "securityContext": {
      "privileged": "true"
    }
  }
}